---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
---

<BaseLayout title="Purchase Agreement | Pampered Feline Maine Coons" description="A plain-language summary of our purchase agreement. Every Pampered Feline kitten is sold with a written contract that protects the kitten first.">

  <!-- Page Header -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory-warm">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-6">
          Terms of Sale
        </p>
        <h1 class="font-heading text-4xl md:text-5xl font-semibold text-charcoal mb-8 leading-tight">
          Our Purchase Agreement
        </h1>
        <p class="text-charcoal-light text-lg leading-relaxed">
          Every Pampered Feline kitten is sold with a written purchase agreement. The contract protects the kitten first. Here is a summary of our terms.
        </p>
      </div>
    </section>
  </ScrollReveal>

  <!-- Contract Terms -->
  <section class="py-16 md:py-24 bg-ivory">
    <div class="max-w-3xl mx-auto px-4">
      <div class="divide-y divide-charcoal/10">

        <ScrollReveal animation="fadeUp" delay={0}>
          <details class="group py-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-heading text-xl md:text-2xl font-semibold text-charcoal pr-4">
                Deposit and Payment
              </h2>
              <svg class="w-5 h-5 text-charcoal-light flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
              </svg>
            </summary>
            <p class="text-charcoal-light leading-relaxed mt-4 pr-10">
              A $400 non-refundable deposit is due upon signing your purchase agreement. This deposit secures your reservation and is applied toward the total purchase price. The remaining balance is due one week before your kitten goes home. We accept Zelle and bank wire transfer only.
            </p>
          </details>
        </ScrollReveal>

        <ScrollReveal animation="fadeUp" delay={0.07}>
          <details class="group py-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-heading text-xl md:text-2xl font-semibold text-charcoal pr-4">
                Spay/Neuter
              </h2>
              <svg class="w-5 h-5 text-charcoal-light flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
              </svg>
            </summary>
            <p class="text-charcoal-light leading-relaxed mt-4 pr-10">
              All pet kittens are sold on a spay/neuter contract. Alteration is required by 10 months of age for both sexes. CFA pedigree papers are withheld until you submit documentation of the procedure from your veterinarian.
            </p>
          </details>
        </ScrollReveal>

        <ScrollReveal animation="fadeUp" delay={0.14}>
          <details class="group py-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-heading text-xl md:text-2xl font-semibold text-charcoal pr-4">
                Health Guarantee
              </h2>
              <svg class="w-5 h-5 text-charcoal-light flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
              </svg>
            </summary>
            <p class="text-charcoal-light leading-relaxed mt-4 pr-10">
              A veterinary exam is required within 72 hours of pickup. We provide a one-year guarantee against hereditary or congenital conditions. FeLV/FIV testing is required within 72 hours of pickup as a condition of the guarantee. Kittens leave health-checked and current on vaccinations.
            </p>
          </details>
        </ScrollReveal>

        <ScrollReveal animation="fadeUp" delay={0.21}>
          <details class="group py-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-heading text-xl md:text-2xl font-semibold text-charcoal pr-4">
                Indoor Only
              </h2>
              <svg class="w-5 h-5 text-charcoal-light flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
              </svg>
            </summary>
            <p class="text-charcoal-light leading-relaxed mt-4 pr-10">
              All Pampered Feline kittens are placed as indoor-only companions. Free-roaming outdoor access is not permitted. Supervised harness walks and enclosed catios are acceptable. This protects the health, safety, and longevity of your cat.
            </p>
          </details>
        </ScrollReveal>

        <ScrollReveal animation="fadeUp" delay={0.28}>
          <details class="group py-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-heading text-xl md:text-2xl font-semibold text-charcoal pr-4">
                No Declawing
              </h2>
              <svg class="w-5 h-5 text-charcoal-light flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
              </svg>
            </summary>
            <p class="text-charcoal-light leading-relaxed mt-4 pr-10">
              Declawing is prohibited under our contract. It is an amputation procedure with documented long-term physical and behavioral consequences. Any buyer who declaw their kitten is required to return the cat to us immediately. Regular nail trimming and quality scratching posts are the appropriate alternatives.
            </p>
          </details>
        </ScrollReveal>

        <ScrollReveal animation="fadeUp" delay={0.35}>
          <details class="group py-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-heading text-xl md:text-2xl font-semibold text-charcoal pr-4">
                Rehoming
              </h2>
              <svg class="w-5 h-5 text-charcoal-light flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
              </svg>
            </summary>
            <p class="text-charcoal-light leading-relaxed mt-4 pr-10">
              We retain first right of refusal if you can no longer keep your cat at any point in its life. Surrendering a Pampered Feline cat to a shelter or rescue is not permitted. Transfers to another household require our written approval. We take this responsibility seriously and will work with you to find the right solution.
            </p>
          </details>
        </ScrollReveal>

        <ScrollReveal animation="fadeUp" delay={0.42}>
          <details class="group py-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-heading text-xl md:text-2xl font-semibold text-charcoal pr-4">
                Breeding Restriction
              </h2>
              <svg class="w-5 h-5 text-charcoal-light flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
              </svg>
            </summary>
            <p class="text-charcoal-light leading-relaxed mt-4 pr-10">
              All kittens are sold as pet-only companions unless a separate written breeding rights agreement is executed prior to purchase. Breeding rights are available on a case-by-case basis to approved CFA or TICA registered catteries with documented health testing programs. Unauthorized breeding is a breach of contract.
            </p>
          </details>
        </ScrollReveal>

        <ScrollReveal animation="fadeUp" delay={0.49}>
          <details class="group py-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-heading text-xl md:text-2xl font-semibold text-charcoal pr-4">
                What Comes With Your Kitten
              </h2>
              <svg class="w-5 h-5 text-charcoal-light flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
              </svg>
            </summary>
            <div class="mt-4 pr-10">
              <p class="text-charcoal-light leading-relaxed mb-4">
                Every Pampered Feline kitten goes home with the following:
              </p>
              <ul class="space-y-2">
                {[
                  "Veterinary health certificate",
                  "Vaccination records",
                  "Both parents' health testing documentation (HCM echocardiogram results and Wisdom Panel genetic reports)",
                  "Signed purchase agreement",
                  "Kitten care guide",
                  "Food sample",
                  "Transition litter",
                  "Familiar toy or blanket",
                  "Personality assessment card describing your kitten's temperament",
                  "CFA pedigree papers after proof of spay/neuter",
                ].map((item) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-4 h-4 text-gold-dark flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-charcoal-light leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        </ScrollReveal>

      </div>
    </div>
  </section>

  <!-- Footer CTA -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory-warm">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-6 leading-tight">
          Questions About Our Contract?
        </h2>
        <p class="text-charcoal-light text-lg leading-relaxed mb-10">
          Have questions about our contract? Contact us.
        </p>
        <a href="/contact" class="inline-block px-8 py-3 bg-charcoal text-ivory text-sm font-medium tracking-widest uppercase hover:bg-charcoal-light transition-colors">
          Contact Us
        </a>
      </div>
    </section>
  </ScrollReveal>

</BaseLayout>
