---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | Pampered Feline Maine Coons">
  <section class="py-24 md:py-36 lg:py-44">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-6">
        404
      </p>
      <h1 class="font-heading text-4xl md:text-5xl font-semibold text-charcoal mb-6 leading-tight">
        Page Not Found
      </h1>
      <p class="text-charcoal-light text-lg leading-relaxed mb-10">
        The page you are looking for does not exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block px-8 py-3 bg-charcoal text-ivory text-sm font-medium tracking-widest uppercase hover:bg-charcoal-light transition-colors"
      >
        Return Home
      </a>
    </div>
  </section>
</BaseLayout>
