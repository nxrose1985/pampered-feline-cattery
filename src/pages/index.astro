---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CurrentLitter from "../components/CurrentLitter.astro";
import AdoptionSteps from "../components/AdoptionSteps.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
---

<BaseLayout
  title="Maine Coon Kittens for Sale in Northern Virginia | Pampered Feline Maine Coons"
  description="European-line Maine Coon kittens raised in Northern Virginia. CFA registered, HCM echo-tested parents, health guaranteed. Now accepting reservations."
>

  <Hero />

  <CurrentLitter />

  <!-- Gradient bridge: obsidian → ivory-warm -->
  <div aria-hidden="true" class="h-16 md:h-20 bg-gradient-to-b from-obsidian to-ivory-warm"></div>

  <!-- Editorial Block -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory-warm">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-6">
          Our Philosophy
        </p>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-semibold text-charcoal mb-8 leading-tight">
          A Small Program With High Standards
        </h2>
        <p class="text-charcoal-light text-lg leading-relaxed mb-6">
          Pampered Feline is a home-based Maine Coon cattery in Northern Virginia. We breed selectively, with limited litters, careful pairings, and hands-on care from birth. Every kitten leaves with a health guarantee, a written contract, and a family that knows their name.
        </p>
        <p class="text-charcoal-light text-lg leading-relaxed">
          Our kittens are raised underfoot from day one, with DNA-tested parents screened for the conditions that matter in the breed, and temperaments selected for confidence and steady company.
        </p>
      </div>
    </section>
  </ScrollReveal>

  <!-- Health & Ethics Preview -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-6">
          Commitment to Care
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-8 leading-tight">
          Health, Ethics, and Care
        </h2>
        <p class="text-charcoal-light text-lg leading-relaxed mb-10">
          We DNA-test our breeding cats for HCM, SMA, and PKDef. Hearts are monitored as cats mature. We follow a transparent, written ethical standard and work with a feline-friendly veterinarian.
        </p>
        <a
          href="/health-ethics"
          class="inline-block px-8 py-3 border border-charcoal text-charcoal text-sm font-medium tracking-widest uppercase hover:bg-charcoal hover:text-ivory transition-colors"
        >
          Learn More
        </a>
      </div>
    </section>
  </ScrollReveal>

  <ScrollReveal animation="fadeUp">
    <AdoptionSteps />
  </ScrollReveal>

</BaseLayout>
