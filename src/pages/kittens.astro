---
import BaseLayout from "../layouts/BaseLayout.astro";
import KittenCard from "../components/KittenCard.astro";
import CheckIcon from "../components/CheckIcon.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import { getKittens, getSettings } from "../lib/sanity";

const [sanityKittens, settings] = await Promise.all([getKittens(), getSettings()]);

// Spring 2026 litter — finalized slate
const fallbackKittens = [
  { name: "Helion",   sex: "Male",   color: "Cream Shaded Silver", status: "Available" as const, isPolydactyl: false, litter: "spring-2026", price: 4000 },
  { name: "Tarquin",  sex: "Male",   color: "Cream Shaded Silver", status: "Available" as const, isPolydactyl: false, litter: "spring-2026", price: 4000 },
  { name: "Kallias",  sex: "Male",   color: "Cream Shaded Silver", status: "Available" as const, isPolydactyl: true,  litter: "spring-2026", price: 4500 },
  { name: "Azriel",   sex: "Male",   color: "Blue Silver Tabby",   status: "Available" as const, isPolydactyl: true,  litter: "spring-2026", price: 4200 },
  { name: "Lucien",   sex: "Male",   color: "Red Tabby",           status: "Available" as const, isPolydactyl: true,  litter: "spring-2026", price: 4200 },
  { name: "Morrigan", sex: "Female", color: "Blue Tortie",         status: "Available" as const, isPolydactyl: false, litter: "spring-2026", price: 3600 },
  { name: "Amren",    sex: "Female", color: "Blue Tortie",         status: "Available" as const, isPolydactyl: false, litter: "spring-2026", price: 3600 },
];

const kittens = sanityKittens.length > 0 ? sanityKittens : fallbackKittens;

const paymentMethods = settings.paymentMethods ?? "[PLACEHOLDER]";
---

<BaseLayout
  title="Maine Coon Kittens Available Now | Northern Virginia | Pampered Feline"
  description="Maine Coon kittens available in Northern Virginia. Silver, polydactyl, and rare colors. CFA registered, health tested, sold with contract. Prices from $3,600."
>

  <!-- Page Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center bg-obsidian overflow-hidden">
    <div class="absolute inset-0 kittens-hero-grain pointer-events-none" aria-hidden="true"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto py-20">
      <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold/70 mb-6">
        Spring 2026
      </p>
      <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl font-semibold text-bone leading-[1.05] mb-8 tracking-tight">
        Spring 2026 Kittens
      </h1>
      <p class="font-body text-base md:text-lg text-bone/55 max-w-xl mx-auto leading-relaxed mb-4">
        Seven kittens available. CFA registered, European lines, HCM echo-negative parents. Ready to go home June through July.
      </p>
      <p class="text-bone/35 text-sm tracking-widest uppercase mb-10">
        Reservations are now open
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-3 bg-bone text-obsidian text-sm font-medium tracking-widest uppercase hover:bg-ivory transition-colors"
      >
        Reserve Your Kitten
      </a>
    </div>
  </section>

  <!-- Gradient bridge: obsidian → ivory -->
  <div aria-hidden="true" class="h-16 md:h-20 bg-gradient-to-b from-obsidian to-ivory"></div>

  <style>
    .kittens-hero-grain {
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
      background-size: 180px 180px;
      mix-blend-mode: overlay;
      opacity: 0.5;
    }
  </style>

  <!-- Available Kittens Grid -->
  <section class="py-16 md:py-24 bg-ivory">
    <div class="max-w-6xl mx-auto px-4">
      <ScrollReveal animation="fadeUp">
        <div class="text-center mb-10 md:mb-14">
          <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-4">
            Available Now
          </p>
          <h2 class="font-heading text-3xl md:text-4xl font-semibold text-charcoal leading-tight">
            Spring 2026 Kittens
          </h2>
        </div>
      </ScrollReveal>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {kittens.map((kitten: any, i: number) => (
          <ScrollReveal animation="fadeUp" delay={i * 0.08}>
            <KittenCard
              name={kitten.name}
              sex={kitten.sex}
              color={kitten.color ?? ""}
              status={kitten.status}
              image={kitten.image?.asset?.url}
              isPolydactyl={kitten.isPolydactyl}
              personality={kitten.personality}
              personalityAssessment={kitten.personalityAssessment}
              price={kitten.price}
            />
          </ScrollReveal>
        ))}
      </div>
      <p class="text-center text-charcoal-light/50 text-sm mt-10">
        Photos added as kittens are weaned and individual personalities emerge. Check back weekly.
      </p>
    </div>
  </section>

  <!-- About This Litter -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory-warm">
      <div class="max-w-4xl mx-auto px-4">
        <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-6 text-center">
          The Pairing
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-12 text-center leading-tight">
          About This Litter
        </h2>

        <!-- Sire & Dam -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-14">
          <div class="border-l-2 border-gold/40 pl-6">
            <p class="text-xs font-medium tracking-[0.3em] uppercase text-gold-dark mb-2">Sire</p>
            <h3 class="font-heading text-2xl font-semibold text-charcoal mb-1">AS11</h3>
            <p class="text-charcoal-light">Blue Shaded Silver Male. European lines. CFA registered.</p>
          </div>
          <div class="border-l-2 border-gold/40 pl-6">
            <p class="text-xs font-medium tracking-[0.3em] uppercase text-gold-dark mb-2">Dam</p>
            <h3 class="font-heading text-2xl font-semibold text-charcoal mb-1">F22</h3>
            <p class="text-charcoal-light">Black Tortie Female. Polydactyl. European lines. CFA registered.</p>
          </div>
        </div>

        <!-- Differentiators -->
        <div class="space-y-10">
          <div>
            <h3 class="font-heading text-xl md:text-2xl font-semibold text-charcoal mb-3">Silver Inhibitor Gene</h3>
            <p class="text-charcoal-light leading-relaxed">
              AS11 carries the inhibitor gene that produces silver and smoke coloring. This litter has a high probability of silver-series kittens — shaded silver, smoke, and chinchilla expressions alongside standard solids and tabbies. Silver-series Maine Coons are among the most striking in the breed.
            </p>
          </div>
          <div>
            <h3 class="font-heading text-xl md:text-2xl font-semibold text-charcoal mb-3">Polydactyl Trait</h3>
            <p class="text-charcoal-light leading-relaxed">
              F22 is a verified polydactyl queen. Three kittens in this litter carry extra toes, a naturally occurring trait associated with broader, well-rounded paws. Polydactyl Maine Coons are relatively rare outside specific bloodlines and carry a premium price as a result.
            </p>
          </div>
          <div>
            <h3 class="font-heading text-xl md:text-2xl font-semibold text-charcoal mb-3">HCM Echo Testing</h3>
            <p class="text-charcoal-light leading-relaxed">
              Both parents have been echocardiographed by a board-certified cardiologist and returned normal results. HCM echo is the gold standard for cardiac screening in Maine Coons. DNA testing alone does not detect all forms of the disease. We do both.
            </p>
          </div>
          <div>
            <h3 class="font-heading text-xl md:text-2xl font-semibold text-charcoal mb-3">Genetic Testing</h3>
            <p class="text-charcoal-light leading-relaxed">
              Both parents completed Wisdom Panel genetic screening covering HCM, SMA, PKDef, and additional markers relevant to the breed. Results on file and available on request.
            </p>
          </div>
        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- Pricing -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory">
      <div class="max-w-4xl mx-auto px-4">
        <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-6 text-center">
          Investment
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-4 text-center leading-tight">
          Pricing
        </h2>
        <p class="text-charcoal-light text-center mb-10 max-w-xl mx-auto">
          All kittens are pet-only and CFA registered. Pricing reflects color rarity and polydactyl status.
        </p>

        <!-- Pricing Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">

          <div class="border border-charcoal/10 p-6 bg-ivory-warm">
            <p class="text-xs font-medium tracking-[0.3em] uppercase text-gold-dark mb-3">Standard</p>
            <p class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-3">$3,600</p>
            <p class="text-charcoal-light text-sm leading-relaxed">Standard pet kittens. Solid colors, tabbies, and non-silver patterns.</p>
          </div>

          <div class="border border-charcoal/10 p-6 bg-ivory-warm">
            <p class="text-xs font-medium tracking-[0.3em] uppercase text-gold-dark mb-3">Rare Color</p>
            <p class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-3">$4,000</p>
            <p class="text-charcoal-light text-sm leading-relaxed">Silver, smoke, and shaded patterns. Rarer color expressions with the inhibitor gene.</p>
          </div>

          <div class="border border-charcoal/10 p-6 bg-ivory-warm">
            <p class="text-xs font-medium tracking-[0.3em] uppercase text-gold-dark mb-3">Polydactyl</p>
            <p class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-3">$4,200</p>
            <p class="text-charcoal-light text-sm leading-relaxed">Standard-color kittens with extra toes. Broader paws, rare trait, limited availability.</p>
          </div>

          <div class="border border-gold/30 p-6 bg-ivory-warm relative">
            <span class="absolute top-4 right-4 text-[10px] tracking-[0.2em] uppercase font-medium text-gold-dark bg-gold/10 px-2 py-0.5">Most Rare</span>
            <p class="text-xs font-medium tracking-[0.3em] uppercase text-gold-dark mb-3">Rare Color Polydactyl</p>
            <p class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-3">$4,500</p>
            <p class="text-charcoal-light text-sm leading-relaxed">Silver or smoke coloring combined with polydactyl. The rarest combination in this litter.</p>
          </div>

        </div>

        <div class="border-t border-charcoal/10 pt-8 text-center space-y-2">
          <p class="text-charcoal-light">
            Non-refundable deposit: <span class="font-medium text-charcoal">$400</span>, applied to the purchase price at pickup.
          </p>
          <p class="text-charcoal-light/60 text-sm">
            Payment methods: {paymentMethods}
          </p>
        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- What Comes With Your Kitten -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory-warm">
      <div class="max-w-3xl mx-auto px-4">
        <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-6 text-center">
          Included
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-10 text-center leading-tight">
          What Comes With Your Kitten
        </h2>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">Written contract and health guarantee</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">Age-appropriate vaccines</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">Health certificate</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">Microchip (if applicable)</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">CFA registration papers</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">Wisdom Panel genetic test results on file</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">Starter food</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">Familiar blanket from home</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckIcon />
            <span class="text-charcoal-light leading-relaxed">Lifetime breeder support</span>
          </li>
        </ul>
      </div>
    </section>
  </ScrollReveal>

  <!-- Reservation Process -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory">
      <div class="max-w-4xl mx-auto px-4">
        <p class="text-xs md:text-sm font-medium tracking-[0.3em] uppercase text-gold-dark mb-6 text-center">
          The Process
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-12 text-center leading-tight">
          How to Reserve a Kitten
        </h2>

        <div class="space-y-8">

          <div class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-charcoal text-ivory flex items-center justify-center font-heading text-lg font-semibold">
              1
            </div>
            <div class="pt-1">
              <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Review available kittens and tiers</h3>
              <p class="text-charcoal-light leading-relaxed">
                Browse the kitten cards above. Each card shows color, sex, and polydactyl status. Match the kitten type to the pricing tier that applies.
              </p>
            </div>
          </div>

          <div class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-charcoal text-ivory flex items-center justify-center font-heading text-lg font-semibold">
              2
            </div>
            <div class="pt-1">
              <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Submit a contact form</h3>
              <p class="text-charcoal-light leading-relaxed">
                Fill out the contact form with your household details, kitten preference, and any questions. We read every submission carefully.
              </p>
            </div>
          </div>

          <div class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-charcoal text-ivory flex items-center justify-center font-heading text-lg font-semibold">
              3
            </div>
            <div class="pt-1">
              <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">We follow up within 48 hours</h3>
              <p class="text-charcoal-light leading-relaxed">
                We reach out to answer questions and confirm fit. If it is a good match, we discuss available kittens and select one together.
              </p>
            </div>
          </div>

          <div class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-charcoal text-ivory flex items-center justify-center font-heading text-lg font-semibold">
              4
            </div>
            <div class="pt-1">
              <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Pay the $400 deposit</h3>
              <p class="text-charcoal-light leading-relaxed">
                The deposit is non-refundable and applied to your purchase price at pickup. It removes your kitten from availability and confirms the reservation.
              </p>
            </div>
          </div>

          <div class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-charcoal text-ivory flex items-center justify-center font-heading text-lg font-semibold">
              5
            </div>
            <div class="pt-1">
              <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Updates, pickup, or transport</h3>
              <p class="text-charcoal-light leading-relaxed">
                We send regular photo and video updates as kittens grow. Kittens go home at 12 weeks with all documentation. We do not ship kittens as air cargo. Kittens travel with a professional flight nanny in-cabin, or can be picked up in person at our Northern Virginia location. Flight nanny fees vary by destination and are the buyer's responsibility.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- Dual CTAs -->
  <ScrollReveal animation="fadeUp">
    <section class="py-16 md:py-24 bg-ivory-warm">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-charcoal mb-4 leading-tight">
          Ready to get started?
        </h2>
        <p class="text-charcoal-light text-lg leading-relaxed mb-10">
          Reach out through the contact page to start the process, or visit the FAQ if you have questions first.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-block px-8 py-3 bg-charcoal text-ivory text-sm font-medium tracking-widest uppercase hover:bg-charcoal-light transition-colors"
          >
            Contact Us
          </a>
          <a
            href="/faq"
            class="inline-block px-8 py-3 border border-charcoal text-charcoal text-sm font-medium tracking-widest uppercase hover:bg-charcoal hover:text-ivory transition-colors"
          >
            Read the FAQ
          </a>
        </div>
      </div>
    </section>
  </ScrollReveal>

</BaseLayout>
