---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/our-cats", label: "Our Cats" },
  { href: "/#kittens", label: "Kittens" },
  { href: "/health-ethics", label: "Health & Ethics" },
  { href: "/faq", label: "FAQ" },
  { href: "/contract", label: "Contract" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 bg-ivory/95 backdrop-blur-sm border-b border-gold/10">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-heading text-xl md:text-2xl font-semibold tracking-wide text-charcoal">
      Pampered Feline
    </a>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-charcoal"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium tracking-widest uppercase text-charcoal-light hover:text-gold-dark transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gold/10">
    <ul class="flex flex-col px-4 py-4 gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block text-sm font-medium tracking-widest uppercase text-charcoal-light hover:text-gold-dark transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
  });
</script>
