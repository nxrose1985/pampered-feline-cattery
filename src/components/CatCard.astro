---
interface Props {
  name: string;
  color: string;
  traits?: string;
  health?: string;
  image?: string;
  gallery?: Array<{ asset: { url: string } }>;
  wisdomPanelPdf?: string;
  variant?: "light" | "dark";
}

const { name, color, traits, health, image, gallery, wisdomPanelPdf, variant = "light" } = Astro.props;
const isDark = variant === "dark";

const galleryUrls = (gallery ?? []).map((g) => g.asset.url).filter(Boolean);
const allImages = image ? [image, ...galleryUrls] : galleryUrls;

function sanityCardUrl(url: string): string {
  if (!url || !url.includes('cdn.sanity.io')) return url;
  return `${url}?w=800&q=80&auto=format`;
}
const displayImages = allImages.map(sanityCardUrl);
---

<div class={`rounded-sm overflow-hidden ${isDark ? "bg-bone/[0.04] border border-bone/10" : "bg-ivory-warm"}`}>
  {allImages.length > 0 ? (
    <div
      class={`relative aspect-square overflow-hidden ${isDark ? "bg-bone/[0.03]" : "bg-charcoal/5"} cursor-pointer`}
      data-cat-carousel={allImages.length > 1 ? JSON.stringify(displayImages) : undefined}
      data-lightbox-images={JSON.stringify(allImages)}
      data-lightbox-name={name}
      data-lightbox-trigger=""
      data-lightbox-index="0"
      data-lightbox-alt={`${name} Maine Coon`}
      role="button"
      tabindex="0"
      aria-label={`View photos of ${name}`}
    >
      {allImages.length === 1 ? (
        <img
          src={displayImages[0]}
          alt={`${name}, ${color} Maine Coon`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <>
          {displayImages.map((src, i) => (
            <img
              src={src}
              alt={`${name}, ${color} Maine Coon`}
              class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-[1200ms] ease-in-out ${i === 0 ? "opacity-100" : "opacity-0"}`}
              data-cat-slide={i}
              loading={i === 0 ? "eager" : "lazy"}
            />
          ))}
          <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
            {allImages.map((_, i) => (
              <span
                class={`w-1.5 h-1.5 rounded-full transition-opacity duration-300 ${i === 0 ? "bg-white opacity-90" : "bg-white opacity-40"}`}
                data-cat-dot={i}
              />
            ))}
          </div>
        </>
      )}
    </div>
  ) : (
    <div class={`aspect-square flex items-center justify-center ${isDark ? "bg-bone/[0.03]" : "bg-charcoal/5"}`}>
      <div class="text-center px-6">
        <svg class={`w-12 h-12 mx-auto mb-2 ${isDark ? "text-bone/20" : "text-charcoal/20"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class={`text-xs uppercase tracking-widest ${isDark ? "text-bone/30" : "text-charcoal/30"}`}>Photo Coming Soon</p>
      </div>
    </div>
  )}
  <div class="p-6">
    <h3 class={`font-heading text-2xl font-semibold mb-1 ${isDark ? "text-bone" : "text-charcoal"}`}>{name}</h3>
    <p class={`text-sm uppercase tracking-widest mb-4 ${isDark ? "text-gold/70" : "text-gold-dark"}`}>{color}</p>
    {traits && (
      <p class={`leading-relaxed mb-3 ${isDark ? "text-bone/70" : "text-charcoal-light"}`}>{traits}</p>
    )}
    {health && (
      <p class={`text-sm leading-relaxed ${isDark ? "text-bone/50" : "text-charcoal-light/70"}`}>{health}</p>
    )}
    {wisdomPanelPdf && (
      <a
        href={wisdomPanelPdf}
        target="_blank"
        rel="noopener noreferrer"
        class={`inline-flex items-center gap-1.5 text-xs font-medium uppercase tracking-widest mt-3 transition-colors ${isDark ? "text-gold/60 hover:text-gold" : "text-gold-dark/70 hover:text-gold-dark"}`}
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        View Genetic Report
      </a>
    )}
  </div>
</div>

<script>
function initCatCarousels() {
  document.querySelectorAll('[data-cat-carousel]').forEach(container => {
    const el = container as HTMLElement;
    const images: string[] = JSON.parse(el.dataset.catCarousel!);
    if (images.length < 2) return;

    const slides = el.querySelectorAll<HTMLElement>('[data-cat-slide]');
    const dots = el.querySelectorAll<HTMLElement>('[data-cat-dot]');
    let current = 0;
    let paused = false;
    let timer: ReturnType<typeof setInterval> | null = null;

    function goTo(idx: number) {
      slides[current]?.classList.replace('opacity-100', 'opacity-0');
      dots[current]?.classList.replace('opacity-90', 'opacity-40');
      current = idx;
      slides[current]?.classList.replace('opacity-0', 'opacity-100');
      dots[current]?.classList.replace('opacity-40', 'opacity-90');
      el.dataset.lightboxIndex = String(current);
    }

    function startTimer() {
      if (timer) clearInterval(timer);
      timer = setInterval(() => {
        if (!paused) goTo((current + 1) % slides.length);
      }, 4000);
    }

    el.addEventListener('mouseenter', () => { paused = true; });
    el.addEventListener('mouseleave', () => { paused = false; });

    let touchStartX = 0;
    el.addEventListener('touchstart', (e) => {
      touchStartX = (e as TouchEvent).touches[0].clientX;
      paused = true;
    }, { passive: true });
    el.addEventListener('touchend', (e) => {
      const dx = (e as TouchEvent).changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 30 && slides.length > 1) {
        goTo(dx < 0 ? (current + 1) % slides.length : (current - 1 + slides.length) % slides.length);
      }
      setTimeout(() => { paused = false; }, 1000);
    }, { passive: true });

    document.addEventListener('astro:before-swap', () => {
      if (timer) clearInterval(timer);
    }, { once: true });

    startTimer();
  });
}

document.addEventListener('DOMContentLoaded', initCatCarousels);
document.addEventListener('astro:page-load', initCatCarousels);
</script>
