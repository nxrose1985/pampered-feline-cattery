---
interface Props {
  name: string;
  color: string;
  traits?: string;
  health?: string;
  image?: string;
}

const { name, color, traits, health, image } = Astro.props;
---

<div class="bg-ivory-warm rounded-sm overflow-hidden">
  <div class="aspect-[4/5] bg-charcoal/5 flex items-center justify-center">
    {image ? (
      <img src={image} alt={`${name}, ${color} Maine Coon`} class="w-full h-full object-cover" />
    ) : (
      <div class="text-center px-6">
        <svg class="w-12 h-12 mx-auto text-charcoal/20 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-xs text-charcoal/30 uppercase tracking-widest">Photo Coming Soon</p>
      </div>
    )}
  </div>
  <div class="p-6">
    <h3 class="font-heading text-2xl font-semibold text-charcoal mb-1">{name}</h3>
    <p class="text-sm text-gold-dark uppercase tracking-widest mb-4">{color}</p>
    {traits && (
      <p class="text-charcoal-light leading-relaxed mb-3">{traits}</p>
    )}
    {health && (
      <p class="text-sm text-charcoal-light/70 leading-relaxed">{health}</p>
    )}
  </div>
</div>
