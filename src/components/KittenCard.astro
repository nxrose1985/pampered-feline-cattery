---
interface PersonalityAssessment {
  assessmentDate?: string;
  confidenceLevel?: number;
  energyLevel?: string;
  approachesHumans?: string;
  lapCat?: string;
  toyDrive?: string;
  hotDogTest?: string;
  goodWithKids?: string;
  goodWithDogs?: string;
  personalitySummary?: string;
}

interface Props {
  name: string;
  sex: string;
  color: string;
  personality?: string;
  status: "Available" | "Reserved" | "Under Evaluation";
  image?: string;
  gallery?: Array<{ asset: { url: string } }>;
  price?: number;
  isPolydactyl?: boolean;
  availableDate?: string;
  variant?: "light" | "dark";
  personalityAssessment?: PersonalityAssessment;
  linkTo?: string;
}

const {
  name,
  sex,
  color,
  personality,
  status,
  image,
  gallery,
  price,
  isPolydactyl,
  availableDate,
  variant = "light",
  personalityAssessment,
  linkTo,
} = Astro.props;

const galleryUrls = (gallery ?? []).map((g) => g.asset.url).filter(Boolean);
const allImages = image ? [image, ...galleryUrls] : galleryUrls;

const pa = personalityAssessment;
const hasAssessment = pa && (pa.personalitySummary || pa.confidenceLevel || pa.energyLevel);

function formatAssessmentDate(d?: string) {
  if (!d) return null;
  const match = /^\d{4}-\d{2}-\d{2}$/.test(d);
  if (!match) return d;
  const [, m, day] = d.split("-").map(Number);
  const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return `${months[m - 1]} ${day}`;
}

const isDark = variant === "dark";

const statusColorsLight: Record<string, string> = {
  "Available": "bg-green/10 text-green",
  "Reserved": "bg-gold/10 text-gold-dark",
  "Under Evaluation": "bg-charcoal/10 text-charcoal-light",
};

const statusColorsDark: Record<string, string> = {
  "Available": "bg-green-light/25 text-bone",
  "Reserved": "bg-gold/20 text-gold",
  "Under Evaluation": "bg-bone/10 text-bone/70",
};

const statusClass = (isDark ? statusColorsDark : statusColorsLight)[status];

function formatPrice(p?: number) {
  if (p === undefined || p === null) return null;
  if (p === 0) return "[PLACEHOLDER — price]";
  return `$${p.toLocaleString("en-US")}`;
}

function formatDate(d?: string) {
  if (!d) return null;
  const match = /^\d{4}-\d{2}-\d{2}$/.test(d);
  if (!match) return d;
  const [y, m, day] = d.split("-").map(Number);
  const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return `${months[m - 1]} ${day}, ${y}`;
}

const priceLabel = formatPrice(price);
const dateLabel = formatDate(availableDate);
---

<div
  class={`rounded-sm overflow-hidden ${isDark ? "bg-bone/[0.04] border border-bone/10" : "bg-ivory-warm"} ${linkTo ? "cursor-pointer" : ""}`}
  {...linkTo ? { onclick: `window.location='${linkTo}'` } : {}}
>
  {allImages.length > 1 ? (
    <div
      class={`relative aspect-[4/5] overflow-hidden ${isDark ? "bg-bone/[0.03]" : "bg-charcoal/5"} cursor-pointer`}
      data-carousel={JSON.stringify(allImages)}
      data-carousel-name={name}
      data-lightbox-images={JSON.stringify(allImages)}
      data-lightbox-name={name}
      data-lightbox-trigger=""
      data-lightbox-index="0"
      role="button"
      tabindex="0"
      aria-label={`View photos of ${name}`}
    >
      {allImages.map((src, i) => (
        <img
          src={src}
          alt={`${name}, ${color} Maine Coon kitten`}
          class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-[2000ms] ease-linear ${i === 0 ? "opacity-100" : "opacity-0"}`}
          data-carousel-slide={i}
        />
      ))}

      {isPolydactyl && (
        <span class={`absolute top-4 left-4 px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-sm z-10 ${isDark ? "bg-gold/20 text-gold" : "bg-charcoal text-ivory"}`}>
          Polydactyl
        </span>
      )}

      <span class={`absolute top-4 right-4 px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-sm z-10 ${statusClass}`}>
        {status}
      </span>

      <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10" data-carousel-dots>
        {allImages.map((_, i) => (
          <span
            class={`w-1.5 h-1.5 rounded-full transition-opacity duration-300 ${i === 0 ? "bg-white opacity-90" : "bg-white opacity-30"}`}
            data-carousel-dot={i}
          />
        ))}
      </div>
    </div>
  ) : (
    <div
      class={`relative aspect-[4/5] flex items-center justify-center ${isDark ? "bg-bone/[0.03]" : "bg-charcoal/5"} ${allImages.length > 0 ? "cursor-pointer" : ""}`}
      {...allImages.length > 0 ? {
        "data-lightbox-trigger": "",
        "data-lightbox-images": JSON.stringify(allImages),
        "data-lightbox-name": name,
        "role": "button",
        "tabindex": "0",
        "aria-label": `View photos of ${name}`,
      } : {}}
    >
      {image ? (
        <img src={image} alt={`${name}, ${color} Maine Coon kitten`} class="w-full h-full object-cover" />
      ) : (
        <div class="text-center px-6">
          <svg class={`w-12 h-12 mx-auto mb-2 ${isDark ? "text-bone/20" : "text-charcoal/20"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class={`text-xs uppercase tracking-widest ${isDark ? "text-bone/30" : "text-charcoal/30"}`}>Photo Coming Soon</p>
        </div>
      )}

      {isPolydactyl && (
        <span class={`absolute top-4 left-4 px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-sm ${isDark ? "bg-gold/20 text-gold" : "bg-charcoal text-ivory"}`}>
          Polydactyl
        </span>
      )}

      <span class={`absolute top-4 right-4 px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-sm ${statusClass}`}>
        {status}
      </span>
    </div>
  )}

  <div class="p-6">
    <h3 class={`font-heading text-2xl font-semibold mb-1 ${isDark ? "text-bone" : "text-charcoal"}`}>{name}</h3>
    <p class={`text-sm uppercase tracking-widest mb-1 ${isDark ? "text-gold" : "text-gold-dark"}`}>{color}</p>
    <p class={`text-sm mb-4 ${isDark ? "text-bone/60" : "text-charcoal-light/70"}`}>{sex}</p>

    {(priceLabel || dateLabel) && (
      <dl class={`text-xs uppercase tracking-widest space-y-1 mb-4 ${isDark ? "text-bone/70" : "text-charcoal-light"}`}>
        {priceLabel && (
          <div class="flex justify-between gap-4">
            <dt class={isDark ? "text-bone/40" : "text-charcoal-light/60"}>Price</dt>
            <dd class="font-medium">{priceLabel}</dd>
          </div>
        )}
        {dateLabel && (
          <div class="flex justify-between gap-4">
            <dt class={isDark ? "text-bone/40" : "text-charcoal-light/60"}>Ready</dt>
            <dd class="font-medium">{dateLabel}</dd>
          </div>
        )}
      </dl>
    )}

    {personality && !pa?.personalitySummary && (
      <p class={`leading-relaxed mb-4 ${isDark ? "text-bone/80" : "text-charcoal-light"}`}>{personality}</p>
    )}

    {hasAssessment && (
      <div class={`mb-4 pt-4 border-t ${isDark ? "border-bone/10" : "border-charcoal/10"}`}>
        {pa?.personalitySummary && (
          <p class={`leading-relaxed mb-4 ${isDark ? "text-bone/80" : "text-charcoal-light"}`}>{pa.personalitySummary}</p>
        )}

        <dl class={`grid grid-cols-2 gap-x-4 gap-y-2 text-xs ${isDark ? "text-bone/70" : "text-charcoal-light"}`}>
          {pa?.confidenceLevel && (
            <div class="col-span-2">
              <dt class={`uppercase tracking-widest mb-1 ${isDark ? "text-bone/40" : "text-charcoal-light/60"}`}>Confidence</dt>
              <dd class="flex items-center gap-0.5">
                {Array.from({ length: 10 }, (_, i) => (
                  <span class={`w-2 h-2 rounded-full ${i < (pa?.confidenceLevel ?? 0) ? (isDark ? "bg-gold" : "bg-gold-dark") : (isDark ? "bg-bone/15" : "bg-charcoal/10")}`} />
                ))}
                <span class={`ml-2 text-xs ${isDark ? "text-bone/50" : "text-charcoal-light/60"}`}>{pa.confidenceLevel}/10</span>
              </dd>
            </div>
          )}
          {pa?.energyLevel && (
            <div>
              <dt class={`uppercase tracking-widest ${isDark ? "text-bone/40" : "text-charcoal-light/60"}`}>Energy</dt>
              <dd class="font-medium mt-0.5">{pa.energyLevel}</dd>
            </div>
          )}
          {pa?.approachesHumans && (
            <div>
              <dt class={`uppercase tracking-widest ${isDark ? "text-bone/40" : "text-charcoal-light/60"}`}>With People</dt>
              <dd class="font-medium mt-0.5">{pa.approachesHumans}</dd>
            </div>
          )}
          {pa?.lapCat && (
            <div>
              <dt class={`uppercase tracking-widest ${isDark ? "text-bone/40" : "text-charcoal-light/60"}`}>Lap Cat</dt>
              <dd class="font-medium mt-0.5">{pa.lapCat}</dd>
            </div>
          )}
          {pa?.hotDogTest && (
            <div>
              <dt class={`uppercase tracking-widest ${isDark ? "text-bone/40" : "text-charcoal-light/60"}`}>Food Motivated</dt>
              <dd class="font-medium mt-0.5">{pa.hotDogTest}</dd>
            </div>
          )}
          {pa?.goodWithKids && (
            <div>
              <dt class={`uppercase tracking-widest ${isDark ? "text-bone/40" : "text-charcoal-light/60"}`}>Kids</dt>
              <dd class="font-medium mt-0.5">{pa.goodWithKids}</dd>
            </div>
          )}
          {pa?.goodWithDogs && (
            <div>
              <dt class={`uppercase tracking-widest ${isDark ? "text-bone/40" : "text-charcoal-light/60"}`}>Dogs</dt>
              <dd class="font-medium mt-0.5">{pa.goodWithDogs}</dd>
            </div>
          )}
          {pa?.toyDrive && (
            <div class="col-span-2">
              <dt class={`uppercase tracking-widest ${isDark ? "text-bone/40" : "text-charcoal-light/60"}`}>Play</dt>
              <dd class="font-medium mt-0.5">{pa.toyDrive}</dd>
            </div>
          )}
        </dl>

        {pa?.assessmentDate && (
          <p class={`mt-3 text-xs ${isDark ? "text-bone/30" : "text-charcoal-light/40"}`}>
            Assessed {formatAssessmentDate(pa.assessmentDate)}
          </p>
        )}
      </div>
    )}

    {status === "Available" && !linkTo && (
      <a
        href="/contact"
        class={`inline-block px-6 py-2 border text-xs font-medium tracking-widest uppercase transition-colors ${
          isDark
            ? "border-bone text-bone hover:bg-bone hover:text-obsidian"
            : "border-charcoal text-charcoal hover:bg-charcoal hover:text-ivory"
        }`}
      >
        Inquire
      </a>
    )}
  </div>
</div>

<script>
  function initCarousels() {
    document.querySelectorAll('[data-carousel]').forEach(container => {
      const el = container as HTMLElement;
      const images = el.querySelectorAll<HTMLElement>('[data-carousel-slide]');
      const dots = el.querySelectorAll<HTMLElement>('[data-carousel-dot]');
      const total = images.length;
      if (total <= 1) return;

      let idx = 0;
      let timer: ReturnType<typeof setInterval> | null = null;
      let paused = false;

      function goTo(n: number) {
        images[idx].classList.remove('opacity-100');
        images[idx].classList.add('opacity-0');
        dots[idx].classList.remove('opacity-90');
        dots[idx].classList.add('opacity-30');

        idx = (n + total) % total;

        images[idx].classList.remove('opacity-0');
        images[idx].classList.add('opacity-100');
        dots[idx].classList.remove('opacity-30');
        dots[idx].classList.add('opacity-90');

        el.dataset.lightboxIndex = String(idx);
      }

      function startTimer() {
        if (timer) clearInterval(timer);
        timer = setInterval(() => { if (!paused) goTo(idx + 1); }, 4000);
      }

      el.addEventListener('mouseenter', () => { paused = true; });
      el.addEventListener('mouseleave', () => { paused = false; });

      // Track touch delta to distinguish tap vs swipe
      let touchStartX = 0;
      let touchMoved = false;

      let resumeTimeout: ReturnType<typeof setTimeout> | null = null;
      el.addEventListener('touchstart', (e) => {
        touchStartX = (e as TouchEvent).touches[0].clientX;
        touchMoved = false;
        paused = true;
        el.dataset.swipedLast = '0';
        if (resumeTimeout) clearTimeout(resumeTimeout);
      }, { passive: true });

      el.addEventListener('touchmove', (e) => {
        const dx = Math.abs((e as TouchEvent).touches[0].clientX - touchStartX);
        if (dx > 10) touchMoved = true;
      }, { passive: true });

      el.addEventListener('touchend', () => {
        el.dataset.swipedLast = touchMoved ? '1' : '0';
        if (resumeTimeout) clearTimeout(resumeTimeout);
        resumeTimeout = setTimeout(() => { paused = false; }, 1000);
      }, { passive: true });

      startTimer();
      document.addEventListener('astro:before-swap', () => {
        if (timer) { clearInterval(timer); timer = null; }
      }, { once: true });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousels);
  } else {
    initCarousels();
  }
</script>
