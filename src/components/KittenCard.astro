---
interface Props {
  name: string;
  sex: string;
  color: string;
  personality?: string;
  status: "Available" | "Reserved" | "Under Evaluation";
  image?: string;
}

const { name, sex, color, personality, status, image } = Astro.props;

const statusColors: Record<string, string> = {
  "Available": "bg-green/10 text-green",
  "Reserved": "bg-gold/10 text-gold-dark",
  "Under Evaluation": "bg-charcoal/10 text-charcoal-light",
};
---

<div class="bg-ivory-warm rounded-sm overflow-hidden">
  <div class="relative aspect-[4/5] bg-charcoal/5 flex items-center justify-center">
    {image ? (
      <img src={image} alt={`${name}, ${color} Maine Coon kitten`} class="w-full h-full object-cover" />
    ) : (
      <div class="text-center px-6">
        <svg class="w-12 h-12 mx-auto text-charcoal/20 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-xs text-charcoal/30 uppercase tracking-widest">Photo Coming Soon</p>
      </div>
    )}
    <span class={`absolute top-4 right-4 px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-sm ${statusColors[status]}`}>
      {status}
    </span>
  </div>
  <div class="p-6">
    <h3 class="font-heading text-2xl font-semibold text-charcoal mb-1">{name}</h3>
    <p class="text-sm text-gold-dark uppercase tracking-widest mb-1">{color}</p>
    <p class="text-sm text-charcoal-light/70 mb-4">{sex}</p>
    {personality && (
      <p class="text-charcoal-light leading-relaxed mb-4">{personality}</p>
    )}
    {status === "Available" && (
      <a
        href="/contact"
        class="inline-block px-6 py-2 border border-charcoal text-charcoal text-xs font-medium tracking-widest uppercase hover:bg-charcoal hover:text-ivory transition-colors"
      >
        Inquire
      </a>
    )}
  </div>
</div>
