---
interface Props {
  variant?: "light" | "dark";
}
const { variant = "light" } = Astro.props;
const isDark = variant === "dark";

const labelClass = `block text-sm font-medium tracking-widest uppercase mb-2 ${isDark ? "text-bone/60" : "text-charcoal-light"}`;
const inputClass = `w-full px-4 py-3 text-base border transition-colors focus:outline-none ${isDark ? "bg-obsidian border-bone/15 text-bone placeholder-bone/30 focus:border-gold" : "bg-ivory-warm border-charcoal/15 text-charcoal placeholder-charcoal/30 focus:border-gold-dark"}`;
---

<form
  id="contact-form"
  name="contact"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="max-w-xl mx-auto space-y-6"
>
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden">
    <label>
      Don't fill this out if you're human: <input name="bot-field" />
    </label>
  </p>

  <div id="contact-fields" class="space-y-6">
    <div>
      <label for="name" class={labelClass}>Name</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class={inputClass}
        placeholder="Your full name"
      />
    </div>

    <div>
      <label for="email" class={labelClass}>Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class={inputClass}
        placeholder="your@email.com"
      />
    </div>

    <div>
      <label for="location" class={labelClass}>City / State</label>
      <input
        type="text"
        id="location"
        name="location"
        class={inputClass}
        placeholder="Where are you located?"
      />
    </div>

    <div>
      <label for="message" class={labelClass}>Message</label>
      <textarea
        id="message"
        name="message"
        rows="5"
        required
        class={`${inputClass} resize-vertical`}
        placeholder="Tell us about yourself and what you're looking for."
      ></textarea>
    </div>
  </div>

  <div class="space-y-4">
    <button
      type="submit"
      id="contact-submit"
      class={`w-full sm:w-auto px-8 py-3 text-sm font-medium tracking-widest uppercase transition-colors cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed ${isDark ? "bg-bone text-obsidian hover:bg-bone/85" : "bg-charcoal text-ivory hover:bg-charcoal-light"}`}
    >
      Send Message
    </button>

    <p id="contact-success" class="hidden text-sm leading-relaxed" style="color: #86efac;">
      Message sent. We'll be in touch within 24 hours.
    </p>

    <p id="contact-error" class="hidden text-sm leading-relaxed" style="color: #fca5a5;">
      Something went wrong. Please email us directly at
      <a href="mailto:pamperedfelinemainecoons@gmail.com" class="underline underline-offset-2">
        pamperedfelinemainecoons@gmail.com
      </a>.
    </p>
  </div>
</form>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const fields = document.getElementById("contact-fields");
  const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement | null;
  const successMsg = document.getElementById("contact-success");
  const errorMsg = document.getElementById("contact-error");

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending…";
      }
      if (errorMsg) errorMsg.classList.add("hidden");

      try {
        const formData = new FormData(form);
        const params = new URLSearchParams();
        formData.forEach((value, key) => params.append(key, value.toString()));

        const response = await fetch("/", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: params.toString(),
        });

        if (response.ok) {
          if (fields) fields.style.display = "none";
          if (submitBtn) submitBtn.style.display = "none";
          if (successMsg) successMsg.classList.remove("hidden");
        } else {
          throw new Error(`status ${response.status}`);
        }
      } catch {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = "Send Message";
        }
        if (errorMsg) errorMsg.classList.remove("hidden");
      }
    });
  }
</script>
