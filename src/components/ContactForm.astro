---

---

<form
  name="contact"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="max-w-xl mx-auto space-y-6"
>
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden">
    <label>
      Don't fill this out if you're human: <input name="bot-field" />
    </label>
  </p>

  <div>
    <label for="name" class="block text-sm font-medium tracking-widest uppercase text-charcoal-light mb-2">
      Name
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-3 bg-ivory-warm border border-charcoal/15 text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold-dark transition-colors"
      placeholder="Your full name"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium tracking-widest uppercase text-charcoal-light mb-2">
      Email
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 bg-ivory-warm border border-charcoal/15 text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold-dark transition-colors"
      placeholder="your@email.com"
    />
  </div>

  <div>
    <label for="location" class="block text-sm font-medium tracking-widest uppercase text-charcoal-light mb-2">
      City / State
    </label>
    <input
      type="text"
      id="location"
      name="location"
      class="w-full px-4 py-3 bg-ivory-warm border border-charcoal/15 text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold-dark transition-colors"
      placeholder="Where are you located?"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-medium tracking-widest uppercase text-charcoal-light mb-2">
      Message
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-3 bg-ivory-warm border border-charcoal/15 text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold-dark transition-colors resize-vertical"
      placeholder="Tell us about yourself and what you're looking for."
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full sm:w-auto px-8 py-3 bg-charcoal text-ivory text-sm font-medium tracking-widest uppercase hover:bg-charcoal-light transition-colors cursor-pointer"
  >
    Send Message
  </button>
</form>
