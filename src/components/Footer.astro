---
import { getSettings } from "../lib/sanity";

const settings = await getSettings();
const currentYear = new Date().getFullYear();

const email = settings.contactEmail ?? "[PLACEHOLDER]";
---

<footer class="bg-charcoal text-ivory/80">
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-8">
      <div class="text-center md:text-left">
        <p class="font-heading text-2xl font-semibold text-ivory mb-2">
          Pampered Feline Maine Coons
        </p>
        <p class="text-sm text-ivory/60">
          Northern Virginia
        </p>
      </div>

      <div class="text-center md:text-right space-y-2">
        <p class="text-sm">
          Email: <span class="text-ivory/60">{email}</span>
        </p>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-ivory/10 text-center">
      <p class="text-xs text-ivory/40">
        &copy; {currentYear} Pampered Feline Maine Coons. All rights reserved.
      </p>
    </div>
  </div>
</footer>
