---
import KittenCard from "./KittenCard.astro";
import ScrollReveal from "./ScrollReveal.astro";
import { getKittensByLitter } from "../lib/sanity";
import type { Kitten } from "../lib/sanity";

interface Props {
  litterId?: string;
}

const { litterId = "march-2026" } = Astro.props;

const sanityKittens = await getKittensByLitter(litterId);

const fallbackKittens = [
  { name: "Helion",  color: "Cream Shaded Silver", sex: "Male",  status: "Available" as const, isPolydactyl: false, litter: litterId, price: 4000, reservationFee: 400, availableDate: "2026-06-04", breed: "Maine Coon", order: 1 },
  { name: "Tarquin", color: "Cream Shaded Silver", sex: "Male",  status: "Available" as const, isPolydactyl: false, litter: litterId, price: 4000, reservationFee: 400, availableDate: "2026-06-04", breed: "Maine Coon", order: 2 },
  { name: "Kallias", color: "Poly Cream Shaded Silver (6/6/6/6)", sex: "Male",  status: "Available" as const, isPolydactyl: true,  litter: litterId, price: 4500, reservationFee: 400, availableDate: "2026-06-04", breed: "Maine Coon", order: 3 },
];

const allKittens = sanityKittens.length > 0 ? sanityKittens : fallbackKittens;
const kittens = allKittens
  .filter((k: any) => k.status === "Available")
  .slice(0, 3);
---

<section class="py-16 md:py-24 bg-obsidian text-bone">
  <div class="max-w-6xl mx-auto px-4">
    <ScrollReveal animation="fadeUp">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-semibold text-bone mb-4 leading-tight">
          Current Litter
        </h2>
        <p class="text-bone/60 text-sm md:text-base tracking-wide">
          Born March 12, 2026 · CFA x TICA · Ready June 4 – July 8
        </p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {kittens.map((kitten: any, i: number) => (
        <ScrollReveal animation="fadeUp" delay={i * 0.1}>
          <KittenCard
            name={kitten.name}
            sex={kitten.sex}
            color={kitten.color}
            personality={kitten.personality}
            status={kitten.status}
            image={kitten.image?.asset?.url}
            price={kitten.price}
            isPolydactyl={kitten.isPolydactyl}
            availableDate={kitten.availableDate}
            variant="dark"
            personalityAssessment={kitten.personalityAssessment}
          />
        </ScrollReveal>
      ))}
    </div>

    <div class="text-center mt-12 md:mt-16">
      <a
        href="/kittens"
        class="inline-block px-8 py-3 border border-bone text-bone text-sm font-medium tracking-widest uppercase hover:bg-bone hover:text-obsidian transition-colors"
      >
        View Full Details
      </a>
    </div>
  </div>
</section>
